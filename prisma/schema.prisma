generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENTIDADES PRINCIPALES ====================

model Company {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  customDomain       String?  @unique
  email              String
  phone              String?
  whatsappCentral    String?
  address            String?
  city               String?
  logoUrl            String?
  currencyPreference String   @default("BOTH") // BOTH | ARS | USD
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relaciones
  users             User[]
  units             Unit[]
  leads             Lead[]
  deals             Deal[]
  whatsappTemplates WhatsAppTemplate[]
  publicClickEvents PublicClickEvent[]
  
  // Audit & RBAC
  auditLogs AuditLog[]
  roles     Role[]

  // Billing
  subscription SaasSubscription?

  @@map("Company")
}

model User {
  id             String   @id @default(cuid())
  email          String
  name           String
  password       String
  role           UserRole @default(SELLER)
  isActive       Boolean  @default(true)
  whatsappNumber String?
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relaciones CRM
  assignedLeads Lead[]         @relation("AssignedLeads")
  createdLeads  Lead[]         @relation("CreatedLeads")
  tasks         Task[]         @relation("AssignedTasks")
  activities    LeadActivity[]
  deals         Deal[]
  
  // Audit trail
  auditLogs AuditLog[]
  
  // Custom roles (for advanced RBAC)
  customRoles Role[] @relation("UserRoles")

  @@unique([email, companyId])
  @@index([companyId])
  @@map("User")
}

// ==================== LEADS Y CRM ====================

model Lead {
  id         String     @id @default(cuid())
  name       String
  phone      String
  email      String?
  source     LeadSource @default(OTHER)
  status     LeadStatus @default(NEW)
  lostReason String?
  notes      String?
  quickInfo  String? // Texto pegado para parseo rápido
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("AssignedLeads", fields: [assignedToId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedLeads", fields: [createdById], references: [id])

  // Unidad de interés (link directo)
  interestedUnitId String?
  interestedUnit   Unit?   @relation("LeadInterestedUnit", fields: [interestedUnitId], references: [id])

  // Relaciones CRM
  activities LeadActivity[]
  tasks      Task[]
  deals      Deal[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, assignedToId])
  @@map("Lead")
}

model LeadActivity {
  id        String       @id @default(cuid())
  type      ActivityType
  notes     String?
  createdAt DateTime     @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  companyId String

  @@index([leadId])
  @@index([companyId])
  @@map("LeadActivity")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedToId String
  assignedTo   User   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  companyId String

  @@index([leadId])
  @@index([companyId])
  @@index([assignedToId, isCompleted])
  @@map("Task")
}

// ==================== UNIDADES (INVENTARIO) ====================

model Unit {
  id          String     @id @default(cuid())
  type        UnitType
  title       String
  description String?
  status      UnitStatus @default(AVAILABLE)
  location    String?
  tags        String[] // Array de tags
  isActive    Boolean    @default(true)

  // Precios
  priceArs Decimal? @db.Decimal(12, 2)
  priceUsd Decimal? @db.Decimal(12, 2)

  // Identificadores únicos por tipo
  vin                String? // Auto (Vehicle Identification Number)
  domain             String? // Auto (patente/dominio)
  engineNumber       String? // Moto
  frameNumber        String? // Moto
  hin                String? // Lancha (Hull Identification Number)
  registrationNumber String? // Lancha

  // Adquisición
  acquisitionCostArs Decimal?        @db.Decimal(12, 2)
  acquisitionCostUsd Decimal?        @db.Decimal(12, 2)
  acquisitionType    AcquisitionType @default(PURCHASE)
  acquisitionDate    DateTime?

  // Permuta (si esta unidad vino de una permuta)
  isFromTradeIn Boolean @default(false)
  tradeInId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relaciones
  photos     UnitPhoto[]
  attributes UnitAttribute[]
  costItems  UnitCostItem[]
  deals      Deal[]

  // Leads interesados en esta unidad
  interestedLeads Lead[] @relation("LeadInterestedUnit")

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, type])
  @@map("Unit")
}

model UnitPhoto {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("UnitPhoto")
}

model UnitAttribute {
  id    String @id @default(cuid())
  key   String
  value String

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, key])
  @@index([unitId])
  @@map("UnitAttribute")
}

model UnitCostItem {
  id        String   @id @default(cuid())
  concept   String
  amountArs Decimal? @db.Decimal(12, 2)
  amountUsd Decimal? @db.Decimal(12, 2)
  date      DateTime @default(now())

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("UnitCostItem")
}

// ==================== OPERACIONES (DEALS) ====================

model Deal {
  id String @id @default(cuid())

  status DealStatus @default(NEGOTIATION)

  // Precio final pactado
  finalPrice         Decimal  @db.Decimal(12, 2)
  finalPriceCurrency String   @default("ARS") // ARS | USD
  exchangeRate       Decimal? @db.Decimal(10, 4) // Tipo de cambio al momento del deal

  // Seña / depósito
  depositAmount Decimal?       @db.Decimal(12, 2)
  depositDate   DateTime?
  depositMethod PaymentMethod?

  // Comisión vendedor
  commissionType  CommissionType @default(PERCENTAGE)
  commissionValue Decimal        @default(0) @db.Decimal(10, 2)

  // Pagos recibidos
  payments DealPayment[]

  // Gastos de cierre
  closingCosts DealCostItem[]

  // Permuta
  tradeIn TradeIn?

  notes    String?
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id])

  @@index([companyId])
  @@index([companyId, status])
  @@index([sellerId])
  @@map("Deal")
}

model DealPayment {
  id         String        @id @default(cuid())
  amount     Decimal       @db.Decimal(12, 2)
  currency   Currency      @default(ARS)
  method     PaymentMethod @default(CASH)
  receivedAt DateTime      @default(now())
  notes      String?
  createdAt  DateTime      @default(now())

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("DealPayment")
}

model DealCostItem {
  id        String   @id @default(cuid())
  concept   String
  amountArs Decimal? @db.Decimal(12, 2)
  amountUsd Decimal? @db.Decimal(12, 2)

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("DealCostItem")
}

model TradeIn {
  id String @id @default(cuid())

  // Lo que entrega el cliente
  description   String
  expectedValue Decimal @db.Decimal(12, 2)
  offeredValue  Decimal @db.Decimal(12, 2)
  finalValue    Decimal @db.Decimal(12, 2)

  // Si se convirtió en unidad de stock
  convertedToUnitId String?   @unique
  isConverted       Boolean   @default(false)
  convertedAt       DateTime?

  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("TradeIn")
}

// ==================== WHATSAPP Y CONFIGURACIÓN ====================

model WhatsAppTemplate {
  id        String  @id @default(cuid())
  name      String
  template  String
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("WhatsAppTemplate")
}

// ==================== ANALYTICS PÚBLICO ====================

model PublicClickEvent {
  id        String    @id @default(cuid())
  type      ClickType
  unitId    String?
  metadata  String? // JSON string con info adicional
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, type])
  @@map("PublicClickEvent")
}

// ==================== AUDIT & RBAC ====================

//
// Audit Log - Track all changes for compliance and debugging
///
model AuditLog {
  id        String   @id @default(cuid())
  action    String   @db.VarChar(50) // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  resource  String   @db.VarChar(100) // Lead, Unit, Deal, User, etc.
  resourceId String?
  
  // Before and after state
  before    Json?    // Previous state (nullable for CREATE)
  after     Json?    // New state (nullable for DELETE)
  
  // Request context
  ipAddress String?
  userAgent String?
  reason    String?  // Why the change was made
  
  createdAt DateTime @default(now())

  // Multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("AuditLog")
}

//
// Custom Roles for advanced RBAC
// Allows companies to create custom roles with specific permissions
///
model Role {
  id          String @id @default(cuid())
  name        String // "Manager", "Sales Lead", "Admin", etc.
  description String?
  isDefault   Boolean @default(false) // System roles (ADMIN, MANAGER, SELLER)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenant
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Permissions
  permissions RolePermission[]
  users       User[] @relation("UserRoles")

  // Unique: system roles have no company, custom roles belong to a company
  @@unique([name, companyId])
  @@index([companyId])
  @@map("Role")
}

//
// Permissions - Granular access control
// Define what actions users can perform
///
model Permission {
  id          String @id @default(cuid())
  name        String @unique // "leads:view", "deals:approve", "users:delete"
  description String?
  resource    String // "leads", "deals", "users"
  action      String // "view", "create", "edit", "delete", "approve"
  
  createdAt   DateTime @default(now())

  // Roles that have this permission
  roles RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("Permission")
}

//
// RolePermission - Join table for many-to-many relationship
///
model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  role         Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  MANAGER
  SELLER
}

enum Currency {
  ARS
  USD
}

enum LeadSource {
  INSTAGRAM
  FACEBOOK_MARKETPLACE
  REFERRAL
  WALK_IN
  PHONE
  WEBSITE
  WHATSAPP
  OLX
  AUTOSUSADOS
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  OFFER
  RESERVED
  SOLD
  LOST
}

enum ActivityType {
  WHATSAPP_SENT
  CALL_MADE
  CALL_RECEIVED
  VISIT_DONE
  OFFER_RECEIVED
  EMAIL_SENT
  NOTE_ADDED
  STATUS_CHANGED
  TASK_COMPLETED
}

enum UnitType {
  CAR
  MOTORCYCLE
  BOAT
}

enum UnitStatus {
  AVAILABLE
  IN_PREP
  RESERVED
  SOLD
}

enum AcquisitionType {
  PURCHASE
  TRADE_IN
  CONSIGNMENT
}

enum DealStatus {
  NEGOTIATION
  RESERVED
  APPROVED
  IN_PAYMENT
  DELIVERED
  CANCELED
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  FINANCING
  CRYPTO
  OTHER
}

enum ClickType {
  WHATSAPP_CLICK
  PHONE_CLICK
  UNIT_VIEW
  SHARE_CLICK
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

// ==================== SAAS BILLING ====================

model SaasPlan {
  id               String   @id @default(cuid())
  name             String
  description      String?
  stripeProductId  String   @unique
  stripePriceId    String   @unique
  price            Decimal  @db.Decimal(10, 2)
  currency         String   @default("usd")
  interval         String   @default("month")
  isActive         Boolean  @default(true)
  
  // Features / Quotas
  maxUsers         Int      @default(0) // 0 = unlimited
  maxUnits         Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  subscriptions    SaasSubscription[]

  @@map("SaasPlan")
}

model SaasSubscription {
  id                   String   @id @default(cuid())
  
  companyId            String   @unique
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  planId               String?
  plan                 SaasPlan? @relation(fields: [planId], references: [id])
  
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  
  status               SubscriptionStatus @default(INCOMPLETE)
  
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("SaasSubscription")
}

model SaasUsageEvent {
  id              String   @id @default(cuid())
  companyId       String
  event           String   // e.g., 'unit_added', 'user_added'
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())

  @@index([companyId])
  @@map("SaasUsageEvent")
}
