generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  cuit               String?
  slug               String             @unique
  customDomain       String?            @unique
  email              String
  phone              String?
  whatsappCentral    String?
  address            String?
  city               String?
  logoUrl            String?
  currencyPreference String             @default("BOTH")
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  auditLogs          AuditLog[]
  deals              Deal[]
  leads              Lead[]
  publicClickEvents  PublicClickEvent[]
  roles              Role[]
  subscription       SaasSubscription?
  units              Unit[]
  users              User[]
  whatsappTemplates  WhatsAppTemplate[]
  expenses           CompanyExpense[]
  promissoryNotes    PromissoryNote[]
  digitalDocuments   DigitalDocument[]

  @@map("Company")
}

model User {
  id             String         @id @default(cuid())
  email          String
  name           String
  password       String
  role           UserRole       @default(SELLER)
  isActive       Boolean        @default(true)
  whatsappNumber String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  companyId      String
  avatarUrl      String?
  auditLogs      AuditLog[]
  deals          Deal[]
  assignedLeads  Lead[]         @relation("AssignedLeads")
  createdLeads   Lead[]         @relation("CreatedLeads")
  activities     LeadActivity[]
  tasks          Task[]         @relation("AssignedTasks")
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customRoles    Role[]         @relation("UserRoles")

  @@unique([email, companyId])
  @@index([companyId])
  @@map("User")
}

model Lead {
  id               String         @id @default(cuid())
  name             String
  phone            String
  email            String?
  source           LeadSource     @default(OTHER)
  status           LeadStatus     @default(NEW)
  lostReason       String?
  notes            String?
  quickInfo        String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  companyId        String
  assignedToId     String?
  createdById      String
  interestedUnitId String?
  deals            Deal[]
  assignedTo       User?          @relation("AssignedLeads", fields: [assignedToId], references: [id])
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy        User           @relation("CreatedLeads", fields: [createdById], references: [id])
  interestedUnit   Unit?          @relation("LeadInterestedUnit", fields: [interestedUnitId], references: [id])
  activities       LeadActivity[]
  tasks            Task[]
  promissoryNotes  PromissoryNote[]
  digitalDocuments DigitalDocument[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, assignedToId])
  @@map("Lead")
}

model LeadActivity {
  id          String       @id @default(cuid())
  type        ActivityType
  notes       String?
  createdAt   DateTime     @default(now())
  leadId      String
  createdById String
  companyId   String
  createdBy   User         @relation(fields: [createdById], references: [id])
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([companyId])
  @@map("LeadActivity")
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  leadId       String
  assignedToId String
  companyId    String
  assignedTo   User      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([companyId])
  @@index([assignedToId, isCompleted])
  @@map("Task")
}

model Unit {
  id                 String          @id @default(cuid())
  type               UnitType
  title              String
  description        String?
  status             UnitStatus      @default(AVAILABLE)
  location           String?
  tags               String[]
  isActive           Boolean         @default(true)
  priceArs           Decimal?        @db.Decimal(12, 2)
  priceUsd           Decimal?        @db.Decimal(12, 2)
  vin                String?
  domain             String?
  engineNumber       String?
  frameNumber        String?
  hin                String?
  registrationNumber String?
  acquisitionCostArs Decimal?        @db.Decimal(12, 2)
  acquisitionCostUsd Decimal?        @db.Decimal(12, 2)
  acquisitionType    AcquisitionType @default(PURCHASE)
  acquisitionDate    DateTime?
  isFromTradeIn      Boolean         @default(false)
  tradeInId          String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  companyId          String
  deals              Deal[]
  interestedLeads    Lead[]          @relation("LeadInterestedUnit")
  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attributes         UnitAttribute[]
  costItems          UnitCostItem[]
  photos             UnitPhoto[]
  promissoryNotes    PromissoryNote[]
  digitalDocuments   DigitalDocument[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, type])
  @@map("Unit")
}

model UnitPhoto {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("UnitPhoto")
}

model UnitAttribute {
  id     String @id @default(cuid())
  key    String
  value  String
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, key])
  @@index([unitId])
  @@map("UnitAttribute")
}

model UnitCostItem {
  id        String   @id @default(cuid())
  concept   String
  amountArs Decimal? @db.Decimal(12, 2)
  amountUsd Decimal? @db.Decimal(12, 2)
  date      DateTime @default(now())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("UnitCostItem")
}

model PromissoryNote {
  id           String         @id @default(cuid())
  amount       Decimal        @db.Decimal(12, 2)
  currency     Currency       @default(ARS)
  issueDate    DateTime
  dueDate      DateTime
  notes        String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  unitId       String
  leadId       String
  companyId    String
  unit         Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  installments Installment[]

  @@index([unitId])
  @@index([companyId])
  @@index([companyId, dueDate])
  @@map("PromissoryNote")
}

model Installment {
  id                 String              @id @default(cuid())
  installmentNumber  Int
  amount             Decimal             @db.Decimal(12, 2)
  dueDate            DateTime
  status             InstallmentStatus   @default(PENDING)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  promissoryNoteId   String
  promissoryNote     PromissoryNote      @relation(fields: [promissoryNoteId], references: [id], onDelete: Cascade)

  payments           InstallmentPayment[]

  @@index([promissoryNoteId])
  @@index([dueDate, status])
  @@map("Installment")
}

model InstallmentPayment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  date          DateTime      @default(now())
  method        PaymentMethod @default(CASH)
  notes         String?
  createdAt     DateTime      @default(now())

  installmentId String
  installment   Installment   @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@index([installmentId])
  @@map("InstallmentPayment")
}



model Deal {
  id                 String         @id @default(cuid())
  status             DealStatus     @default(NEGOTIATION)
  finalPrice         Decimal        @db.Decimal(12, 2)
  finalPriceCurrency String         @default("ARS")
  exchangeRate       Decimal?       @db.Decimal(10, 4)
  depositAmount      Decimal?       @db.Decimal(12, 2)
  depositDate        DateTime?
  depositMethod      PaymentMethod?
  commissionType     CommissionType @default(PERCENTAGE)
  commissionValue    Decimal        @default(0) @db.Decimal(10, 2)
  notes              String?
  closedAt           DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  companyId          String
  leadId             String
  unitId             String
  sellerId           String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead               Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  seller             User           @relation(fields: [sellerId], references: [id])
  unit               Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  closingCosts       DealCostItem[]
  payments           DealPayment[]
  tradeIn            TradeIn?

  @@index([companyId])
  @@index([companyId, status])
  @@index([sellerId])
  @@map("Deal")
}

model DealPayment {
  id         String        @id @default(cuid())
  amount     Decimal       @db.Decimal(12, 2)
  currency   Currency      @default(ARS)
  method     PaymentMethod @default(CASH)
  receivedAt DateTime      @default(now())
  notes      String?
  createdAt  DateTime      @default(now())
  dealId     String
  deal       Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("DealPayment")
}

model DealCostItem {
  id        String   @id @default(cuid())
  concept   String
  amountArs Decimal? @db.Decimal(12, 2)
  amountUsd Decimal? @db.Decimal(12, 2)
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("DealCostItem")
}

model TradeIn {
  id                String    @id @default(cuid())
  description       String
  expectedValue     Decimal   @db.Decimal(12, 2)
  offeredValue      Decimal   @db.Decimal(12, 2)
  finalValue        Decimal   @db.Decimal(12, 2)
  convertedToUnitId String?   @unique
  isConverted       Boolean   @default(false)
  convertedAt       DateTime?
  dealId            String    @unique
  deal              Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("TradeIn")
}

model WhatsAppTemplate {
  id        String   @id @default(cuid())
  name      String
  template  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("WhatsAppTemplate")
}

model PublicClickEvent {
  id        String    @id @default(cuid())
  type      ClickType
  unitId    String?
  metadata  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, type])
  @@map("PublicClickEvent")
}

///
model AuditLog {
  id         String   @id @default(cuid())
  action     String   @db.VarChar(50)
  resource   String   @db.VarChar(100)
  resourceId String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  reason     String?
  createdAt  DateTime @default(now())
  companyId  String
  userId     String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("AuditLog")
}

///
model Role {
  id          String           @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companyId   String?
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]           @relation("UserRoles")

  @@unique([name, companyId])
  @@index([companyId])
  @@map("Role")
}

///
model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("Permission")
}

///
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}

model SaasPlan {
  id              String             @id @default(cuid())
  name            String
  description     String?
  stripeProductId String             @unique
  stripePriceId   String             @unique
  price           Decimal            @db.Decimal(10, 2)
  currency        String             @default("usd")
  interval        String             @default("month")
  isActive        Boolean            @default(true)
  maxUsers        Int                @default(0)
  maxUnits        Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  subscriptions   SaasSubscription[]

  @@map("SaasPlan")
}

model SaasSubscription {
  id                   String             @id @default(cuid())
  companyId            String             @unique
  planId               String?
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan                 SaasPlan?          @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("SaasSubscription")
}

model SaasUsageEvent {
  id        String   @id @default(cuid())
  companyId String
  event     String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("SaasUsageEvent")
}

model CompanyExpense {
  id          String   @id @default(cuid())
  companyId   String
  category    String   // Ej: "Mantenimiento", "Sueldos", "Servicios"
  description String?
  amountArs   Decimal  @default(0)
  amountUsd   Decimal  @default(0)
  date        DateTime // Fecha en la que ocurrió el gasto
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([companyId, isActive])
  @@map("CompanyExpense")
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
}

enum UserRole {
  ADMIN
  MANAGER
  SELLER
}

enum Currency {
  ARS
  USD
}

enum LeadSource {
  INSTAGRAM
  FACEBOOK_MARKETPLACE
  REFERRAL
  WALK_IN
  PHONE
  WEBSITE
  WHATSAPP
  OLX
  AUTOSUSADOS
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  OFFER
  RESERVED
  SOLD
  LOST
}

enum ActivityType {
  WHATSAPP_SENT
  CALL_MADE
  CALL_RECEIVED
  VISIT_DONE
  OFFER_RECEIVED
  EMAIL_SENT
  NOTE_ADDED
  STATUS_CHANGED
  TASK_COMPLETED
}

enum UnitType {
  CAR
  MOTORCYCLE
  BOAT
}

enum UnitStatus {
  AVAILABLE
  IN_PREP
  RESERVED
  SOLD
}

enum AcquisitionType {
  PURCHASE
  TRADE_IN
  CONSIGNMENT
}

enum DealStatus {
  NEGOTIATION
  RESERVED
  APPROVED
  IN_PAYMENT
  DELIVERED
  CANCELED
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  FINANCING
  CRYPTO
  OTHER
}

enum ClickType {
  WHATSAPP_CLICK
  PHONE_CLICK
  UNIT_VIEW
  SHARE_CLICK
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum DocumentType {
  BOLETO_COMPRAVENTA
  RECIBO
  CONTRATO
}

enum DocumentStatus {
  DRAFT
  GENERATED
  SIGNED
}

model DigitalDocument {
  id              String         @id @default(cuid())
  type            DocumentType
  referenceNumber String?        
  amount          Decimal?       @db.Decimal(12, 2)
  status          DocumentStatus @default(GENERATED)
  metadata        Json
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  unitId          String
  leadId          String
  companyId       String

  unit            Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lead            Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([unitId])
  @@index([leadId])
  @@map("DigitalDocument")
}
