{
  "_comment": "Variables de entorno requeridas para despliegue en Vercel",
  "required": [
    {
      "name": "DATABASE_URL",
      "description": "URL de conexión a PostgreSQL (Neon)",
      "example": "postgresql://user:pass@host.neon.tech/db?sslmode=require",
      "required": true
    },
    {
      "name": "DIRECT_URL",
      "description": "URL directa para Prisma (sin pooling)",
      "example": "postgresql://user:pass@host.neon.tech/db?sslmode=require",
      "required": true
    },
    {
      "name": "NEXTAUTH_SECRET",
      "description": "Secret para NextAuth (mínimo 32 caracteres)",
      "example": "openssl rand -base64 32",
      "required": true
    },
    {
      "name": "NEXTAUTH_URL",
      "description": "URL de la aplicación",
      "example": "https://tu-app.vercel.app",
      "required": true
    },
    {
      "name": "NEXT_PUBLIC_SUPABASE_URL",
      "description": "URL de Supabase",
      "example": "https://xxxx.supabase.co",
      "required": false,
      "note": "Opcional - usado para storage de imágenes"
    },
    {
      "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
      "description": "Anon key de Supabase",
      "example": "eyJhbGciOiJIUzI1NiIs...",
      "required": false,
      "note": "Opcional - usado para storage de imágenes"
    },
    {
      "name": "SUPABASE_SERVICE_ROLE_KEY",
      "description": "Service role key de Supabase",
      "example": "eyJhbGciOiJIUzI1NiIs...",
      "required": false,
      "note": "Opcional - para operaciones server-side"
    },
    {
      "name": "STRIPE_SECRET_KEY",
      "description": "Secret key de Stripe",
      "example": "sk_live_...",
      "required": false,
      "note": "Opcional - para facturación"
    },
    {
      "name": "STRIPE_WEBHOOK_SECRET",
      "description": "Webhook secret de Stripe",
      "example": "whsec_...",
      "required": false,
      "note": "Opcional - para webhooks de Stripe"
    },
    {
      "name": "SENTRY_DSN",
      "description": "DSN de Sentry para monitoreo de errores",
      "example": "https://xxx@xxx.ingest.sentry.io/xxx",
      "required": false,
      "note": "Recomendado para producción"
    },
    {
      "name": "NODE_ENV",
      "description": "Ambiente de ejecución",
      "example": "production",
      "required": true
    },
    {
      "name": "LOG_LEVEL",
      "description": "Nivel de logging",
      "example": "info",
      "options": ["debug", "info", "warn", "error"],
      "required": false
    }
  ],
  "commands": {
    "generate_secret": "openssl rand -base64 32",
    "deploy": "vercel --prod",
    "deploy_staging": "vercel"
  }
}
